---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFab from '../components/react/WhatsAppFab.tsx';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  current?: string;
}
const {
  title,
  description = 'Aslan Hukuk Bürosu — 2003\'ten bu yana ticaret, iş, aile, ceza, gayrimenkul ve idare hukukunda sessiz, kararlı temsil.',
  current
} = Astro.props;
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0e0c08" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,400..700,30..100,0..1;1,9..144,400..700,30..100,0..1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LegalService',
      name: 'Aslan Hukuk Bürosu',
      url: 'https://aslanhukuk.com.tr',
      telephone: site.phone.replace(/\s+/g,''),
      email: site.email,
      foundingDate: site.established,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Levent Mah. Büyükdere Cad. No:120 K:5',
        addressLocality: 'Şişli',
        addressRegion: 'İstanbul',
        addressCountry: 'TR'
      },
      areaServed: 'Türkiye'
    })} />

    <title>{title}</title>
  </head>
  <body>
    <Header current={current} />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppFab
      client:idle
      phone={site.whatsapp}
      message="Merhaba, hukuki bir konuda görüşme talep etmek istiyorum."
    />
  </body>
</html>
