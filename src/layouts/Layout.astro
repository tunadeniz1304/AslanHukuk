---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  current?: string;
}
const {
  title,
  description = 'Aslan Hukuk Bürosu — 2003\'ten bu yana ticaret, iş, aile, ceza, gayrimenkul ve idare hukukunda sessiz, kararlı temsil.',
  current
} = Astro.props;
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f5f1e8" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Source+Serif+4:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LegalService',
      name: 'Aslan Hukuk Bürosu',
      url: 'https://aslanhukuk.com.tr',
      telephone: '+902125551234',
      email: 'info@aslanhukuk.com.tr',
      foundingDate: '2003',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Levent Mah. Büyükdere Cad. No:120 K:5',
        addressLocality: 'Şişli',
        addressRegion: 'İstanbul',
        addressCountry: 'TR'
      },
      areaServed: 'Türkiye'
    })} />

    <title>{title}</title>
  </head>
  <body>
    <Header current={current} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
