---
interface Props { class?: string; size?: number; }
const { class: cls = '', size = 36 } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  width={size}
  height={size}
  class={cls}
  aria-label="Aslan Hukuk Monogram"
  role="img"
>
  <!-- Outer rule frame -->
  <rect x="1" y="1" width="62" height="62" fill="none" stroke="currentColor" stroke-width="1.5" />
  <!-- Inner crossed serif "A" with horizontal bar -->
  <g stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="square">
    <line x1="14" y1="50" x2="32" y2="14" />
    <line x1="32" y1="14" x2="50" y2="50" />
    <line x1="22" y1="36" x2="42" y2="36" />
  </g>
  <!-- Bottom serif tick -->
  <line x1="22" y1="52" x2="42" y2="52" stroke="currentColor" stroke-width="1.2" />
</svg>
