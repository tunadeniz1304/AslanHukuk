---
interface Props {
  class?: string;
  size?: number;
  alt?: string;
}
const { class: cls = '', size = 36, alt = 'Aslan Hukuk Bürosu Logosu' } = Astro.props;
---
<img
  src="/logo.png"
  alt={alt}
  width={size}
  height={size}
  class={`block object-contain transition duration-300 ${cls}`}
  style={`width:${size}px; height:${size}px;`}
  loading="eager"
  decoding="async"
/>
