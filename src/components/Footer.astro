---
import Monogram from './Monogram.astro';
import { site, nav, practices } from '../data/site';
const year = new Date().getFullYear();

const isReal = (v: string) => v && !v.startsWith('TODO');
const phoneClean = isReal(site.phone) ? site.phone.replace(/\s+/g, '') : '';
---
<footer class="bg-noir text-paper" style="padding: clamp(4rem,8vw,7rem) 0 2rem;">
  <div class="shell">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 pb-12 border-b border-paper/15">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <Monogram class="text-gold" size={42} />
          <span class="font-display text-paper" style="font-size: 1.55rem; font-weight: 500;">Aslan Hukuk</span>
        </div>
        <p class="font-display italic text-paper/80 leading-relaxed" style="max-width: 36ch; font-size: 1.15rem; font-weight:500;">
          Sessiz, kararlı ve tutarlı bireysel hukuk pratiği. Adaletin yanında, müvekkilin omzunda.
        </p>
        <p class="font-mono uppercase text-gold-soft mt-5" style="font-size:0.7rem; letter-spacing:0.22em; font-weight:600;">
          {site.attorney.name}
        </p>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">Sayfalar</h4>
        <ul class="space-y-2.5">
          {nav.map((n) => <li><a href={n.href} class="font-body text-paper/75 hover:text-gold-soft transition" style="font-size: 1rem;">{n.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">Hizmetler</h4>
        <ul class="space-y-2.5">
          {practices.slice(0, 5).map((p) => (
            <li><a href={`/calisma-alanlari#${p.slug}`} class="font-body text-paper/75 hover:text-gold-soft transition" style="font-size: 1rem;">{p.name.split(' ')[0]}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">İletişim</h4>
        <ul class="space-y-2.5 font-body text-paper/75" style="font-size: 1rem;">
          {isReal(site.address) && <li>{site.address}</li>}
          {isReal(site.phone) && <li><a href={`tel:${phoneClean}`} class="hover:text-gold-soft transition">{site.phone}</a></li>}
          {isReal(site.email) && <li><a href={`mailto:${site.email}`} class="hover:text-gold-soft transition">{site.email}</a></li>}
          {!isReal(site.address) && !isReal(site.phone) && !isReal(site.email) && (
            <li class="font-mono uppercase text-gold-soft" style="font-size:0.7rem; letter-spacing:0.22em; font-weight:600;">YAKINDA</li>
          )}
        </ul>
      </div>
    </div>

    <div class="flex flex-wrap justify-between gap-4 pt-8 font-mono uppercase text-paper/45" style="font-size:0.62rem;letter-spacing:0.22em;">
      <span>© {year} Aslan Hukuk Bürosu. Tüm hakları saklıdır.</span>
      <span>Bu site bilgilendirme amaçlıdır; hukuki tavsiye yerine geçmez.</span>
    </div>
  </div>
</footer>
