---
import Monogram from './Monogram.astro';
import { site, nav, practices } from '../data/site';
const year = new Date().getFullYear();

const isReal = (v: string) => v && !v.startsWith('TODO');
const phoneClean = isReal(site.phone) ? site.phone.replace(/\s+/g, '') : '';
---
<footer class="bg-noir text-paper" style="padding: clamp(4rem,8vw,7rem) 0 2rem;">
  <div class="shell">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 pb-12 border-b border-paper/15">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <Monogram class="text-gold-bright" size={36} />
          <span class="font-display text-paper" style="font-size: 1.25rem; font-weight: 500; letter-spacing:-0.012em;">Aslan Hukuk</span>
        </div>
        <p class="font-mono uppercase text-gold-soft mb-6" style="font-size:0.62rem; letter-spacing:0.32em; font-weight:600;">
          {site.attorney.name}
        </p>
        <p class="font-body text-paper/80 leading-relaxed" style="max-width: 38ch; font-size: 1rem;">
          Sessiz, kararlı ve tutarlı bireysel hukuk pratiği. Adaletin yanında, müvekkilin omzunda.
        </p>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">Sayfalar</h4>
        <ul class="space-y-2.5">
          {nav.map((n) => <li><a href={n.href} class="font-body text-paper/75 hover:text-gold-soft transition" style="font-size: 1rem;">{n.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">Hizmetler</h4>
        <ul class="space-y-2.5">
          {practices.slice(0, 5).map((p) => (
            <li><a href={`/calisma-alanlari#${p.slug}`} class="font-body text-paper/75 hover:text-gold-soft transition" style="font-size: 1rem;">{p.name.split(' ')[0]}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-mono uppercase text-gold-soft mb-5" style="font-size:0.66rem;letter-spacing:0.28em;">İletişim</h4>
        <ul class="space-y-2.5 font-body text-paper/75" style="font-size: 1rem;">
          {isReal(site.address) && <li>{site.address}</li>}
          {isReal(site.phone) && <li><a href={`tel:${phoneClean}`} class="hover:text-gold-soft transition">{site.phone}</a></li>}
          {isReal(site.email) && <li><a href={`mailto:${site.email}`} class="hover:text-gold-soft transition">{site.email}</a></li>}
          {!isReal(site.address) && !isReal(site.phone) && !isReal(site.email) && (
            <li class="font-mono uppercase text-gold-soft" style="font-size:0.7rem; letter-spacing:0.22em; font-weight:600;">YAKINDA</li>
          )}
        </ul>

        <h4 class="font-mono uppercase text-gold-soft mt-8 mb-4" style="font-size:0.66rem;letter-spacing:0.28em;">Sosyal</h4>
        <ul class="flex gap-2 list-none p-0 m-0">
          <li>
            <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
               class="grid place-items-center w-10 h-10 border border-paper/20 hover:border-gold-bright hover:text-gold-bright transition text-paper/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
          </li>
          <li>
            <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
               class="grid place-items-center w-10 h-10 border border-paper/20 hover:border-gold-bright hover:text-gold-bright transition text-paper/85">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </a>
          </li>
          {isReal(site.whatsapp) && (
            <li>
              <a href={`https://wa.me/${site.whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
                 class="grid place-items-center w-10 h-10 border border-paper/20 hover:border-gold-bright hover:text-gold-bright transition text-paper/85">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.05 4.91A10.05 10.05 0 0 0 12 2C6.48 2 2 6.48 2 12c0 1.77.46 3.49 1.34 5.01L2 22l5.13-1.34A9.94 9.94 0 0 0 12 22c5.52 0 10-4.48 10-10 0-2.67-1.04-5.18-2.96-7.09zM12 20.13a8.09 8.09 0 0 1-4.13-1.13l-.3-.18-3.05.8.81-2.97-.19-.31A8.05 8.05 0 0 1 3.87 12c0-4.49 3.65-8.13 8.13-8.13 4.49 0 8.13 3.64 8.13 8.13 0 4.49-3.65 8.13-8.13 8.13zm4.46-6.1c-.24-.12-1.45-.72-1.67-.8-.22-.08-.39-.12-.55.12-.16.24-.62.8-.76.96-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.21-1.43-1.35-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.32-.75-1.81-.2-.48-.4-.41-.55-.42l-.47-.01c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2.01 0 1.18.86 2.32.98 2.48.12.16 1.69 2.58 4.1 3.62.57.25 1.02.39 1.37.5.57.18 1.1.16 1.51.1.46-.07 1.45-.59 1.65-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28z"/>
                </svg>
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="flex flex-wrap justify-between gap-4 pt-8 font-mono uppercase text-paper/45" style="font-size:0.62rem;letter-spacing:0.22em;">
      <span>© {year} Aslan Hukuk Bürosu. Tüm hakları saklıdır.</span>
      <span>Bu site bilgilendirme amaçlıdır; hukuki tavsiye yerine geçmez.</span>
    </div>
  </div>
</footer>
