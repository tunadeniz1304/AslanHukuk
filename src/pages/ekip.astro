---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/react/Reveal.tsx';
import { partners, associates } from '../data/site';

// Initials fallback portraits — pure SVG, no external images
const palette = ['#0a0a0a', '#14110b', '#2a2a2a'];
function initials(name: string) {
  return name.replace('Av. ', '').split(' ').map((s) => s[0]).slice(0, 2).join('');
}
---
<Layout title="Ekibimiz — Aslan Hukuk Bürosu" current="/ekip">

  <section class="border-b border-rule" style="padding: clamp(4rem,7vw,7rem) 0 clamp(3rem,5vw,5rem);">
    <div class="shell">
      <Reveal client:visible>
        <div class="mono-meta mb-6 flex items-center gap-3">
          <a href="/" class="text-ink-soft hover:text-gold transition">ANASAYFA</a>
          <span class="text-gold">/</span>
          <span class="text-ink">EKİBİMİZ</span>
        </div>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h1 class="display" style="max-width: 14ch;">İsimlerden<br/>çok, <em style="color:#8a6b2a; font-style:italic;">imzalar</em>.</h1>
      </Reveal>
      <Reveal client:visible delay={0.2}>
        <p class="lead mt-8" style="max-width: 50ch;">
          Aslan Hukuk Bürosu, ortak ve avukatlarının her birinin altına imza atabildiği bir pratiktir.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Partners -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-14 flex-wrap gap-4">
          <div>
            <span class="eyebrow">001 — Yönetici Ortaklar</span>
            <h2 class="h2 mt-6" style="max-width: 14ch;">Büronun yönü.</h2>
          </div>
          <p class="font-mono text-ink-mute m-0" style="font-size:0.7rem; letter-spacing:0.22em;">{partners.length} İSİM</p>
        </div>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-y-14 gap-x-10">
        {partners.map((p, i) => (
          <Reveal client:visible delay={i * 0.08}>
            <article class="flex flex-col group">
              <div class="aspect-[3/4] mb-6 overflow-hidden bg-paper-deep relative">
                <div class="absolute inset-0 grid place-items-center font-serif text-paper transition-transform duration-700 group-hover:scale-105"
                     style={`background:${palette[i % palette.length]}; font-size: clamp(4rem, 8vw, 7rem); letter-spacing:-0.04em;`}>
                  {initials(p.name)}
                </div>
                <div class="absolute bottom-0 left-0 right-0 h-px bg-gold transform scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-700"></div>
              </div>
              <div class="font-mono uppercase text-gold mb-2" style="font-size:0.7rem; letter-spacing:0.22em;">— {p.role}</div>
              <h3 class="h3 mb-2">{p.name}</h3>
              <p class="font-body italic text-ink-mute mb-3" style="font-size:0.95rem;">{p.title}</p>
              <p class="m-0" style="font-size:0.98rem; line-height:1.6; color:#2a2a2a;">{p.bio}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Associates -->
  <section class="bg-paper-deep section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">002 — Avukatlar</span>
            <h2 class="h2 mt-6" style="max-width: 14ch;">Uzman kadromuz.</h2>
          </div>
          <p class="font-mono text-ink-mute m-0" style="font-size:0.7rem; letter-spacing:0.22em;">{associates.length} İSİM</p>
        </div>
      </Reveal>

      <ul class="border-t border-rule list-none p-0 m-0">
        {associates.map((a, i) => (
          <Reveal client:visible delay={i * 0.05}>
            <li class="grid grid-cols-1 md:grid-cols-[80px_1.5fr_1fr_auto] items-center gap-x-8 gap-y-2 py-7 md:py-9 border-b border-rule group hover:bg-paper transition-colors duration-500 px-2 md:px-4">
              <div class="font-mono text-gold" style="font-size:0.8rem; letter-spacing:0.22em;">— 0{i + 1}</div>
              <div class="font-serif" style="font-size: clamp(1.3rem, 2vw, 1.7rem); letter-spacing:-0.015em;">{a.name}</div>
              <div class="font-body italic text-ink-mute" style="font-size:0.95rem;">{a.title}</div>
              <div class="font-mono uppercase text-ink-soft justify-self-end" style="font-size:0.7rem; letter-spacing:0.22em;">{a.role}</div>
            </li>
          </Reveal>
        ))}
      </ul>
    </div>
  </section>

  <!-- Closing -->
  <section class="bg-noir text-paper section">
    <div class="shell text-center">
      <Reveal client:visible>
        <h2 class="font-serif mx-auto" style="font-size: clamp(2.2rem,4vw,3.2rem); line-height:1.06; letter-spacing:-0.02em; max-width: 22ch; color:#f5f1e8;">
          Hangi ortağın, hangi avukatın dosyanıza bakacağını ilk görüşmede birlikte belirleriz.
        </h2>
      </Reveal>
      <Reveal client:visible delay={0.12}>
        <a href="/iletisim" class="ed-btn on-dark mt-10 inline-block">Görüşme Talep Et</a>
      </Reveal>
    </div>
  </section>

</Layout>
