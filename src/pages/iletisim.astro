---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/react/Reveal.tsx';
import ContactForm from '../components/react/ContactForm.tsx';
import { site } from '../data/site';

const isReal = (v: string) => v && !v.startsWith('TODO');
const phoneClean    = isReal(site.phone)    ? site.phone.replace(/\s+/g, '')    : '';
const phoneAltClean = isReal(site.phoneAlt) ? site.phoneAlt.replace(/\s+/g, '') : '';
---
<Layout title="İletişim — Aslan Hukuk Bürosu" current="/iletisim">

  <section class="border-b border-rule" style="padding: clamp(4rem,7vw,7rem) 0 clamp(3rem,5vw,5rem);">
    <div class="shell">
      <Reveal client:visible>
        <div class="mono-meta mb-6 flex items-center gap-3">
          <a href="/" class="text-ink-soft hover:text-gold transition">ANASAYFA</a>
          <span class="text-gold">/</span>
          <span class="text-ink">İLETİŞİM</span>
        </div>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h1 class="display" style="max-width: 13ch;">Önce bir<br/><em class="accent-italic">görüşme</em>.</h1>
      </Reveal>
      <Reveal client:visible delay={0.2}>
        <p class="lead mt-8" style="max-width: 50ch;">
          İlk görüşme takdire bağlı ve gizlidir. Telefonla, e-posta ile veya aşağıdaki formla doğrudan iletişime geçebilirsiniz.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="section">
    <div class="shell grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-start">

      <!-- Meta -->
      <Reveal client:visible>
        <aside>
          <span class="eyebrow">001 — Bilgi</span>
          <h2 class="h2 mt-6 mb-8" style="max-width: 14ch;">Doğrudan ulaşın.</h2>
          <ul class="border-t border-rule list-none p-0 m-0">
            {isReal(site.address) && (
              <li class="border-b border-rule py-6">
                <div class="mono-meta text-ink-mute mb-2">ADRES</div>
                <div class="font-display text-ink" style="font-size:1.2rem; line-height:1.4; font-weight:500;">{site.address}</div>
              </li>
            )}
            {isReal(site.phone) && (
              <li class="border-b border-rule py-6">
                <div class="mono-meta text-ink-mute mb-2">TELEFON</div>
                <a href={`tel:${phoneClean}`} class="font-display text-ink block hover:text-gold transition" style="font-size:1.2rem; font-weight:500;">{site.phone}</a>
                {isReal(site.phoneAlt) && (
                  <a href={`tel:${phoneAltClean}`} class="font-display text-ink-soft block hover:text-gold transition mt-1" style="font-size:1.05rem; font-weight:500;">{site.phoneAlt}</a>
                )}
              </li>
            )}
            {isReal(site.email) && (
              <li class="border-b border-rule py-6">
                <div class="mono-meta text-ink-mute mb-2">E-POSTA</div>
                <a href={`mailto:${site.email}`} class="font-display text-ink block hover:text-gold transition" style="font-size:1.2rem; font-weight:500;">{site.email}</a>
                {isReal(site.emailBooking) && (
                  <a href={`mailto:${site.emailBooking}`} class="font-display text-ink-soft block hover:text-gold transition mt-1" style="font-size:1.05rem; font-weight:500;">{site.emailBooking}</a>
                )}
              </li>
            )}
            <li class="border-b border-rule py-6">
              <div class="mono-meta text-ink-mute mb-2">ÇALIŞMA</div>
              <div class="font-display text-ink" style="font-size:1.2rem; font-weight:500;">{site.hours}</div>
              <div class="font-body text-ink-mute mt-1" style="font-size:0.95rem;">Cumartesi randevu ile</div>
            </li>
            <li class="py-6">
              <div class="mono-meta text-ink-mute mb-3">SOSYAL</div>
              <div class="flex gap-2">
                <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
                   class="grid place-items-center w-10 h-10 border border-rule hover:border-ink hover:bg-ink hover:text-paper transition text-ink">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
                  </svg>
                </a>
                <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                   class="grid place-items-center w-10 h-10 border border-rule hover:border-ink hover:bg-ink hover:text-paper transition text-ink">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                  </svg>
                </a>
                <a href={`https://wa.me/${site.whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
                   class="grid place-items-center w-10 h-10 border border-rule hover:border-ink hover:bg-ink hover:text-paper transition text-ink">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19.05 4.91A10.05 10.05 0 0 0 12 2C6.48 2 2 6.48 2 12c0 1.77.46 3.49 1.34 5.01L2 22l5.13-1.34A9.94 9.94 0 0 0 12 22c5.52 0 10-4.48 10-10 0-2.67-1.04-5.18-2.96-7.09zM12 20.13a8.09 8.09 0 0 1-4.13-1.13l-.3-.18-3.05.8.81-2.97-.19-.31A8.05 8.05 0 0 1 3.87 12c0-4.49 3.65-8.13 8.13-8.13 4.49 0 8.13 3.64 8.13 8.13 0 4.49-3.65 8.13-8.13 8.13zm4.46-6.1c-.24-.12-1.45-.72-1.67-.8-.22-.08-.39-.12-.55.12-.16.24-.62.8-.76.96-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.95-1.2-.72-.64-1.21-1.43-1.35-1.67-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.32-.75-1.81-.2-.48-.4-.41-.55-.42l-.47-.01c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2.01 0 1.18.86 2.32.98 2.48.12.16 1.69 2.58 4.1 3.62.57.25 1.02.39 1.37.5.57.18 1.1.16 1.51.1.46-.07 1.45-.59 1.65-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28z"/>
                  </svg>
                </a>
              </div>
            </li>
            {!isReal(site.address) && !isReal(site.phone) && !isReal(site.email) && (
              <li class="py-6 mono-meta text-gold-deep">İLETİŞİM BİLGİLERİ KISA SÜREDE EKLENECEK.</li>
            )}
          </ul>
        </aside>
      </Reveal>

      <!-- Form -->
      <Reveal client:visible delay={0.1}>
        <div>
          <span class="eyebrow">002 — Form</span>
          <h2 class="h2 mt-6 mb-3" style="max-width: 16ch;">Görüşme talebi.</h2>
          <p class="font-body text-ink-soft mb-10" style="font-size: 1.05rem; max-width: 48ch; line-height: 1.6;">
            Aşağıdaki bilgileri paylaşın; en kısa sürede tarafınıza dönüş yapalım. Tüm bilgileriniz mesleki sır kapsamında korunur.
          </p>
          <ContactForm client:load />
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Map -->
  <section class="border-y border-rule">
    <iframe
      title="Aslan Hukuk Bürosu Konum"
      src="https://www.openstreetmap.org/export/embed.html?bbox=29.005%2C41.075%2C29.025%2C41.085&layer=mapnik"
      style="width:100%; height:480px; border:0; display:block; filter: grayscale(85%) contrast(1.05);"
      loading="lazy"
    ></iframe>
  </section>

</Layout>
