---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/react/Reveal.tsx';
import { site } from '../data/site';

const principles = [
  { no: '01', title: 'Gizlilik',          desc: 'Müvekkil sırrı tartışılmaz. Tüm bilgileriniz, hukukun verdiği güvencenin ötesinde, mesleki vicdanımla korunur.' },
  { no: '02', title: 'İhtisas',           desc: 'Her dosya kendi alanının derinliğiyle çalışılır. Yüzeysel pratik, müvekkilin geleceğini riske atar.' },
  { no: '03', title: 'Sessizlik',         desc: 'Davayı medyada değil, dosyada kazanırım. Müvekkilin itibarını korumak başarımın bir parçasıdır.' },
  { no: '04', title: 'Süreç Şeffaflığı',  desc: 'Müvekkilim, dosyasının her aşamasında nerede olduğunu bilir. Belirsizlik, hizmetimin bir parçası değildir.' },
  { no: '05', title: 'Sonuç Sorumluluğu', desc: 'Aldığım her dosyada, sonuca dair açık ve gerçekçi bir değerlendirme yaparım. Boş vaat vermem.' },
  { no: '06', title: 'Etik Çizgi',        desc: 'Avukatlık mesleğinin etik kurallarına ve hukukun üstünlüğüne, koşulsuz bağlıyım.' },
];

// Gerçek kronoloji
const timeline = [
  { year: '2022', text: 'Çankaya Üniversitesi Hukuk Fakültesi mezuniyeti.' },
  { year: '2022', text: 'Ankara Barosu\'na kayıt; avukatlık ruhsatı.' },
  { year: '2025', text: 'Aslan Hukuk Bürosu\'nun Ankara — Sincan\'da kuruluşu.' },
  { year: '—',    text: 'Ankara Barosu KKTC Başkanı görevi.' },
  { year: '—',    text: 'Çankayalı Hukukçular Derneği Başkan Vekili.' },
];
---
<Layout title="Hakkımızda — Aslan Hukuk Bürosu" current="/hakkimizda">

  <!-- Subhero -->
  <section class="border-b border-rule" style="padding: clamp(4rem,7vw,7rem) 0 clamp(3rem,5vw,5rem);">
    <div class="shell">
      <Reveal client:visible>
        <div class="mono-meta mb-6 flex items-center gap-3">
          <a href="/" class="text-ink-soft hover:text-gold transition">ANASAYFA</a>
          <span class="text-gold">/</span>
          <span class="text-ink">HAKKIMIZDA</span>
        </div>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h1 class="display" style="max-width: 14ch;">
          Bir avukat,<br/>
          <span class="accent-italic">tek bir standart.</span>
        </h1>
      </Reveal>
      <Reveal client:visible delay={0.2}>
        <p class="lead mt-8" style="max-width: 50ch;">
          Aslan Hukuk Bürosu; gösterişli vaatlerle değil, dosyada kazanılan kararlarla büyüyen bireysel bir hukuk pratiğidir.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- KURUCU AVUKAT — büyük portre + kimlik kartı + biyo -->
  <section class="section">
    <div class="shell">
      <div class="grid grid-cols-1 lg:grid-cols-[6fr_6fr] gap-12 lg:gap-16 items-start">

        <Reveal client:visible>
          <div class="relative">
            <div class="aspect-[4/5] bg-noir overflow-hidden relative">
              <img
                src={site.attorney.photo}
                alt={`${site.attorney.name} — ${site.attorney.role}`}
                width="900" height="1125"
                loading="eager"
                decoding="async"
                class="w-full h-full object-cover transition duration-700 hover:scale-[1.02]"
              />
              <div class="absolute left-0 bottom-0 right-0 bg-noir text-paper px-6 py-5 flex items-end justify-between gap-4">
                <div>
                  <div class="font-mono uppercase text-gold-soft mb-1" style="font-size:0.66rem; letter-spacing:0.28em; font-weight:600;">— KURUCU AVUKAT</div>
                  <div class="font-display text-paper" style="font-size: clamp(1.4rem, 2.2vw, 1.8rem); letter-spacing:-0.015em; font-weight:500;">{site.attorney.name}</div>
                </div>
                <div class="font-mono text-gold" style="font-size:0.66rem; letter-spacing:0.22em; font-weight:600;">ANKARA · TÜRKİYE</div>
              </div>
            </div>
            <div class="absolute -bottom-3 -right-3 w-2/3 h-px bg-gold hidden lg:block"></div>
          </div>
        </Reveal>

        <Reveal client:visible delay={0.12}>
          <div>
            <span class="eyebrow">001 — Avukat</span>
            <h2 class="h1 mt-6 mb-8" style="max-width: 16ch;">
              {site.attorney.name}.
            </h2>

            <ul class="border-y border-rule list-none p-0 m-0 mb-8">
              <li class="flex justify-between items-baseline gap-4 py-4 border-b border-rule">
                <span class="mono-meta text-ink-mute">EĞİTİM</span>
                <span class="font-display text-ink text-right" style="font-size:1.05rem; font-weight:500;">{site.attorney.education}</span>
              </li>
              <li class="flex justify-between items-baseline gap-4 py-4 border-b border-rule">
                <span class="mono-meta text-ink-mute">BARO</span>
                <span class="font-display text-ink text-right" style="font-size:1.05rem; font-weight:500;">{site.attorney.barRegistration}</span>
              </li>
              {site.attorney.titles.map((t) => (
                <li class="flex justify-between items-baseline gap-4 py-4 border-b border-rule last:border-b-0">
                  <span class="mono-meta text-gold">GÖREV</span>
                  <span class="font-display text-ink text-right" style="font-size:1.05rem; font-weight:500; max-width: 28ch;">{t.label}</span>
                </li>
              ))}
            </ul>

            <div class="space-y-5 font-body" style="font-size: 1.08rem; line-height: 1.7; color:#1a1a1a;">
              <p style="max-width:none;">
                <span class="font-display" style="font-size:2.4rem; line-height:1; float:left; padding: 4px 12px 0 0; color:#0a0a0a; font-weight:500;">A</span>
                slan Hukuk Bürosu, Av. Mesut Aslan tarafından bireysel pratiğe verilen önemle Ankara'da kuruldu. Bir avukatın değeri, kabul ettiği dosya sayısıyla değil, her birine ayırdığı emekle ölçülür.
              </p>
              <p style="max-width:none;">
                Büromuzda, kalabalık bir ekip yerine; her dosyayı doğrudan kendisi yöneten ve takip eden bir avukat vardır. Bu, müvekkile şu güvenceyi verir: dosyanız hiçbir zaman tanımadığınız bir asistanın masasına devredilmez.
              </p>
              <p style="max-width:none;">
                Av. Mesut Aslan; ticaret, aile, iş, ceza, gayrimenkul ve idare hukuku alanlarında bireysel ve kurumsal müvekkillere doğrudan hizmet vermektedir.
              </p>
            </div>

            <div class="mt-10 flex flex-wrap gap-4">
              <a href="/iletisim" class="ed-btn">Görüşme Talep Et</a>
              <a href="/calisma-alanlari" class="ed-link">Çalışma Alanları</a>
            </div>
          </div>
        </Reveal>

      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-paper-deep section">
    <div class="shell">
      <Reveal client:visible>
        <span class="eyebrow">002 — Kronoloji</span>
        <h2 class="h2 mt-6 mb-12" style="max-width: 16ch;">Eğitimden bireysel pratiğe.</h2>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-y-0 border-t border-rule">
        {timeline.map((t, i) => (
          <>
            <Reveal client:visible delay={i * 0.06}>
              <div class="font-display italic py-6 md:py-8 md:pr-8 border-b border-rule" style="font-size: clamp(1.8rem,3vw,2.5rem); line-height:1; color:#8a6b2a; font-weight:500;">{t.year}</div>
            </Reveal>
            <Reveal client:visible delay={i * 0.06 + 0.04}>
              <div class="font-body py-2 md:py-8 pb-6 md:pb-8 border-b border-rule" style="font-size: 1.1rem; line-height:1.6; color:#1a1a1a; max-width: 60ch;">{t.text}</div>
            </Reveal>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">003 — Prensipler</span>
            <h2 class="h2 mt-6" style="max-width: 14ch;">Pratiğimi yöneten altı çizgi.</h2>
          </div>
        </div>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-t border-rule">
        {principles.map((p, i) => (
          <Reveal client:visible delay={i * 0.06}>
            <article class={`p-8 md:p-10 border-b border-rule ${(i + 1) % 3 !== 0 ? 'lg:border-r' : ''} ${i % 2 === 0 ? 'md:border-r lg:border-r' : ''}`} style="min-height: 280px;">
              <div class="font-mono text-gold mb-5" style="font-size:0.85rem; letter-spacing:0.2em; font-weight:600;">— {p.no}</div>
              <h3 class="h3 mb-4">{p.title}</h3>
              <p class="m-0" style="font-size:1rem; line-height:1.65; color:#1a1a1a;">{p.desc}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Görevler & Üyelikler — noir bölümü, stats yerine -->
  <section class="bg-noir text-paper section">
    <div class="shell">
      <Reveal client:visible>
        <span class="eyebrow on-dark">004 — Görevler &amp; Üyelikler</span>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h2 class="font-display mt-6 mb-12" style="font-size: clamp(2rem,4vw,3.2rem); line-height:1.1; letter-spacing:-0.02em; max-width: 16ch; color:#f5f1e8; font-weight:500;">
          Mesleki sorumluluğun ötesinde, <span class="accent-italic" style="color:#d2ae6f;">temsil görevi</span>.
        </h2>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-2 mt-6 border-t border-paper/15">
        {site.attorney.titles.map((t, i) => (
          <Reveal client:visible delay={i * 0.1}>
            <article class={`py-10 md:py-14 px-2 md:px-8 border-b border-paper/15 ${i === 0 ? 'md:border-r border-paper/15' : ''} flex flex-col gap-6 md:gap-8 h-full`}>
              <div>
                <div class="font-mono text-gold mb-5" style="font-size:0.78rem; letter-spacing:0.22em; font-weight:600;">— 0{i + 1}</div>
                <h3 class="font-display text-paper" style="font-size: clamp(1.4rem,2.2vw,1.85rem); line-height:1.15; letter-spacing:-0.018em; font-weight:500;">{t.label}</h3>
              </div>

              {i === 0 && (
                <figure class="mt-auto m-0 group/photo">
                  <div class="border border-gold/40 p-2 bg-noir-soft transition group-hover/photo:border-gold">
                    <div class="aspect-[4/3] overflow-hidden bg-noir relative">
                      <img
                        src="/photos/mesut-aslan-kktc.jpg"
                        alt="Av. Mesut Aslan — Ankara Barosu KKTC görev fotoğrafı"
                        loading="lazy"
                        decoding="async"
                        class="absolute inset-0 w-full h-full object-cover transition duration-700 group-hover/photo:scale-[1.04]"
                      />
                    </div>
                  </div>
                  <figcaption class="mt-3 font-mono uppercase text-gold-soft" style="font-size:0.62rem; letter-spacing:0.22em; font-weight:600;">
                    — KKTC · GÖREV FOTOĞRAFI
                  </figcaption>
                </figure>
              )}
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

</Layout>
