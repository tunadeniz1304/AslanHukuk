---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/react/Hero.tsx';
import Marquee from '../components/react/Marquee.tsx';
import PracticeList from '../components/react/PracticeList.tsx';
import Reveal from '../components/react/Reveal.tsx';
import { features, approach, site } from '../data/site';
---
<Layout title="Aslan Hukuk Bürosu — Sessiz güç. Kararlı temsil." current="/">

  <Hero client:load />

  <Marquee client:visible items={[
    'TİCARET HUKUKU',
    'AİLE HUKUKU',
    'CEZA HUKUKU',
    'İDARE HUKUKU',
    'GAYRİMENKUL',
    'İŞ HUKUKU',
    'ANKARA BAROSU',
    'BİREYSEL PRATİK',
  ]} />

  <!-- Manifesto (text only — portre artık hero'da) -->
  <section class="bg-noir text-paper" style="padding: clamp(5rem,11vw,11rem) 0;">
    <div class="shell">
      <Reveal client:visible>
        <span class="eyebrow on-dark">001 — Manifesto</span>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <p class="font-display mt-7 mb-10" style="font-size: clamp(2rem,4.5vw,3.6rem); line-height:1.16; letter-spacing:-0.02em; max-width: 22ch; color:#f5f1e8; font-weight:500;">
          Bir hukuk pratiği, gürültüsüyle değil; sessizce kazandığı zaferlerle ölçülür.
          <em style="color:#b59456; font-style:italic; font-variation-settings:'opsz' 144, 'SOFT' 100, 'WONK' 0;"> Sonuçla konuşurum.</em>
        </p>
      </Reveal>
      <Reveal client:visible delay={0.2}>
        <p class="font-display italic" style="color:rgba(245,241,232,0.75); font-size: 1.1rem; font-weight:500;">— {site.attorney.name}, {site.attorney.role}</p>
      </Reveal>
    </div>
  </section>

  <!-- Practice list -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">002 — Çalışma Alanları</span>
            <h2 class="h2 mt-5" style="max-width: 14ch;">İhtisaslaştığım altı hukuk alanı.</h2>
          </div>
          <a href="/calisma-alanlari" class="ed-link">Tümünü incele</a>
        </div>
      </Reveal>
      <PracticeList client:visible />
    </div>
  </section>

  <!-- Features (stats yerine — sayı yerine kalite) -->
  <section class="section-tight">
    <div class="shell">
      <Reveal client:visible>
        <div class="grid grid-cols-1 md:grid-cols-3 border-y border-rule">
          {features.map((f, i) => (
            <div class={`p-8 md:p-12 ${i < features.length - 1 ? 'md:border-r border-rule' : ''} border-b md:border-b-0 border-rule`}>
              <div class="font-mono text-gold mb-4" style="font-size:0.78rem; letter-spacing:0.22em; font-weight:600;">
                — 0{i + 1}
              </div>
              <h3 class="font-display text-ink mb-3" style="font-size: clamp(1.5rem,2.5vw,2rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{f.label}</h3>
              <p class="m-0" style="font-size: 1rem; line-height:1.6; color:#1a1a1a;">{f.desc}</p>
            </div>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Yaklaşım (verdicts yerine — yeni büro için dürüst alternatif) -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">003 — Yaklaşımım</span>
            <h2 class="h2 mt-5" style="max-width: 18ch;">Üç adımda, dosyanızın yanındayım.</h2>
          </div>
          <p class="lead m-0" style="max-width: 32ch;">
            Müvekkille avukat arasında aracı yoktur; süreç açık, gizli ve takip edilebilirdir.
          </p>
        </div>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-3 border-t border-rule">
        {approach.map((a, i) => (
          <Reveal client:visible delay={i * 0.1}>
            <article class={`p-8 md:p-10 border-b border-rule ${i < 2 ? 'md:border-r' : ''} flex flex-col gap-5 min-h-[300px] hover:bg-paper-light transition-colors duration-500`}>
              <div class="flex items-baseline justify-between">
                <span class="font-mono text-gold" style="font-size:0.78rem; letter-spacing:0.22em; font-weight:600;">— {a.no}</span>
                <span class="mono-meta text-ink-mute">ADIM</span>
              </div>
              <h3 class="font-display text-ink m-0" style="font-size: clamp(1.6rem,2.5vw,2.1rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{a.title}</h3>
              <p class="m-0" style="font-size: 1.02rem; line-height:1.65; color:#1a1a1a;">{a.desc}</p>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="bg-noir text-paper section">
    <div class="shell text-center">
      <Reveal client:visible>
        <span class="eyebrow on-dark justify-center mx-auto">004 — Görüşme</span>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h2 class="font-display mt-6 mx-auto" style="font-size: clamp(2.4rem,5vw,4rem); line-height:1.08; letter-spacing:-0.025em; max-width: 18ch; color:#f5f1e8; font-weight:500;">
          Doğru zamanda, <span class="accent-italic" style="color:#d2ae6f;">doğru avukat</span>.
        </h2>
      </Reveal>
      <Reveal client:visible delay={0.18}>
        <p class="lead mx-auto mt-6" style="color:rgba(245,241,232,0.85); max-width: 42ch;">
          İlk görüşme takdire bağlı ve gizlidir. Dosyanızı değerlendirir, yol haritasını birlikte belirleriz.
        </p>
      </Reveal>
      <Reveal client:visible delay={0.26}>
        <div class="mt-10 flex gap-4 justify-center flex-wrap">
          <a href="/iletisim" class="ed-btn on-dark">Görüşme Talep Et</a>
          <a href="/hakkimizda" class="ed-link on-dark">Avukatı tanıyın</a>
        </div>
      </Reveal>
    </div>
  </section>

</Layout>
