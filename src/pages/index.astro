---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/react/Hero.tsx';
import Marquee from '../components/react/Marquee.tsx';
import PracticeList from '../components/react/PracticeList.tsx';
import Reveal from '../components/react/Reveal.tsx';
import { stats, verdicts, site } from '../data/site';
---
<Layout title="Aslan Hukuk Bürosu — Sessiz güç. Kararlı temsil." current="/">

  <Hero client:load />

  <Marquee client:visible items={[
    'TİCARET HUKUKU',
    'AİLE HUKUKU',
    'CEZA HUKUKU',
    'İDARE HUKUKU',
    'GAYRİMENKUL',
    'İŞ HUKUKU',
    'TAHKİM',
    'M&A',
  ]} />

  <!-- Manifesto + Founder portrait split -->
  <section class="bg-noir text-paper" style="padding: clamp(5rem,11vw,11rem) 0;">
    <div class="shell">
      <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-12 lg:gap-16 items-center">

        <div>
          <Reveal client:visible>
            <span class="eyebrow on-dark">001 — Manifesto</span>
          </Reveal>
          <Reveal client:visible delay={0.1}>
            <p class="font-display mt-7 mb-10" style="font-size: clamp(1.9rem,3.6vw,3.2rem); line-height:1.16; letter-spacing:-0.02em; max-width: 22ch; color:#f5f1e8; font-weight:500;">
              Bir hukuk pratiği, gürültüsüyle değil; sessizce kazandığı zaferlerle ölçülür.
              <em style="color:#b59456; font-style:italic; font-variation-settings:'opsz' 144, 'SOFT' 100, 'WONK' 0;"> Sonuçla konuşurum.</em>
            </p>
          </Reveal>
          <Reveal client:visible delay={0.2}>
            <p class="font-display italic" style="color:rgba(245,241,232,0.75); font-size: 1.1rem; font-weight:500;">— {site.attorney.name}, {site.attorney.role}</p>
          </Reveal>
        </div>

        <Reveal client:visible delay={0.15}>
          <figure class="relative">
            <div class="aspect-[4/5] overflow-hidden bg-noir-soft border border-paper/10">
              <img
                src={site.attorney.photo}
                alt={`${site.attorney.name} — ${site.attorney.role}`}
                width="700" height="875"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition duration-700 hover:scale-[1.02]"
              />
            </div>
            <figcaption class="absolute -bottom-3 -right-3 bg-gold text-noir px-4 py-2.5 font-mono uppercase shadow-lg" style="font-size:0.66rem; letter-spacing:0.22em; font-weight:700;">
              KURUCU AVUKAT
            </figcaption>
          </figure>
        </Reveal>

      </div>
    </div>
  </section>

  <!-- Practice list -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">002 — Çalışma Alanları</span>
            <h2 class="h2 mt-5" style="max-width: 14ch;">İhtisaslaştığım altı hukuk alanı.</h2>
          </div>
          <a href="/calisma-alanlari" class="ed-link">Tümünü incele</a>
        </div>
      </Reveal>
      <PracticeList client:visible />
    </div>
  </section>

  <!-- Stats -->
  <section class="section-tight">
    <div class="shell">
      <Reveal client:visible>
        <div class="grid grid-cols-1 md:grid-cols-4 border-y border-rule">
          {stats.map((s, i) => (
            <div class={`p-8 md:p-12 ${i < stats.length - 1 ? 'md:border-r border-rule' : ''} border-b md:border-b-0 border-rule`}>
              <div class="font-display" style="font-size: clamp(2.4rem,4.5vw,3.6rem); line-height:1.05; letter-spacing:-0.03em; font-weight:500;">{s.num}</div>
              <div class="mono-meta mt-3 text-ink-mute">{s.label}</div>
            </div>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Verdicts -->
  <section class="section">
    <div class="shell">
      <Reveal client:visible>
        <div class="flex justify-between items-end mb-12 flex-wrap gap-4">
          <div>
            <span class="eyebrow">003 — Seçilmiş Sonuçlar</span>
            <h2 class="h2 mt-5" style="max-width: 16ch;">Sessizce kazanılmış kararlar.</h2>
          </div>
          <p class="lead m-0" style="max-width: 32ch;">
            Müvekkil gizliliği esastır; sonuçlar, anonimleştirilmiş özet halinde sunulur.
          </p>
        </div>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-3 border-t border-rule">
        {verdicts.map((v, i) => (
          <Reveal client:visible delay={i * 0.08}>
            <article class={`p-8 md:p-10 border-b border-rule ${i < 2 ? 'md:border-r' : ''} flex flex-col gap-5 min-h-[320px] hover:bg-paper-light transition-colors duration-500`}>
              <div class="flex justify-between mono-meta text-ink-mute">
                <span>{v.year}</span>
                <span>{v.area}</span>
              </div>
              <p class="font-display flex-grow m-0" style="font-size: clamp(1.25rem,1.7vw,1.55rem); line-height:1.3; letter-spacing:-0.015em; color:#0a0a0a; font-weight:500;">{v.lede}</p>
              <span class="font-mono uppercase text-gold-deep" style="font-size:0.78rem; letter-spacing:0.18em; font-weight:600;">— {v.outcome}</span>
            </article>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="bg-noir text-paper section">
    <div class="shell text-center">
      <Reveal client:visible>
        <span class="eyebrow on-dark justify-center mx-auto">004 — Görüşme</span>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <h2 class="font-display mt-6 mx-auto" style="font-size: clamp(2.4rem,5vw,4rem); line-height:1.08; letter-spacing:-0.025em; max-width: 18ch; color:#f5f1e8; font-weight:500;">
          Doğru zamanda, <span class="accent-italic" style="color:#d2ae6f;">doğru avukat</span>.
        </h2>
      </Reveal>
      <Reveal client:visible delay={0.18}>
        <p class="lead mx-auto mt-6" style="color:rgba(245,241,232,0.85); max-width: 42ch;">
          İlk görüşme takdire bağlı ve gizlidir. Dosyanızı değerlendirir, yol haritasını birlikte belirleriz.
        </p>
      </Reveal>
      <Reveal client:visible delay={0.26}>
        <div class="mt-10 flex gap-4 justify-center flex-wrap">
          <a href="/iletisim" class="ed-btn on-dark">Görüşme Talep Et</a>
          <a href="/hakkimizda" class="ed-link on-dark">Avukatı tanıyın</a>
        </div>
      </Reveal>
    </div>
  </section>

</Layout>
